# Copia este archivo como ".env" y rellena tus valores reales.
# NUNCA subas el archivo .env real a GitHub.

# Token gratuito de https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=tu_token_aqui

# Cualquier cadena aleatoria, usada por Flask para firmar la sesión/flash
SECRET_KEY=cambia-esto-por-algo-aleatorio

# Opcional: si no se define, se usa SQLite local en instance/quiniela.db
# Ejemplo para Postgres en Railway:
# DATABASE_URL=postgresql://usuario:password@host:puerto/nombre_db
